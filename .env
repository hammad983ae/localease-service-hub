# SendBird Configuration
# Get these values from your SendBird dashboard at https://dashboard.sendbird.com/

# SendBird Application ID (required)
# This is the unique identifier for your SendBird application
VITE_SENDBIRD_APP_ID=8D3AB381-B5B2-4DAA-B7E8-5309741EABF3

# SendBird Platform API Token (optional, for advanced user management)
# This token allows the app to create/manage users via SendBird's Platform API
# Only needed if you want to automatically create users in SendBird
VITE_SENDBIRD_API_TOKEN=d97c5683ad55a926f241f160da05b0b4ca8b65e5

# SendBird Debug Mode (development only)
# Enable detailed logging for debugging SendBird integration issues
# Set to 'true' to enable, 'false' or leave empty to disable
VITE_SENDBIRD_DEBUG=false

# Other Environment Variables
# API Configuration
VITE_API_BASE_URL=http://localhost:5002/api

# Authentication
VITE_JWT_SECRET=your_jwt_secret_here

# Database (if using external database)
VITE_DATABASE_URL=your_database_url_here

# File Storage (if using external storage)
VITE_STORAGE_BUCKET=your_storage_bucket_here
VITE_STORAGE_REGION=your_storage_region_here

# Email Service (if using external email service)
VITE_EMAIL_SERVICE=your_email_service_here
VITE_EMAIL_API_KEY=your_email_api_key_here

# Payment Processing (if using payment services)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
VITE_STRIPE_SECRET_KEY=your_stripe_secret_key_here

# How to get SendBird credentials:
# 1. Go to https://dashboard.sendbird.com/
# 2. Sign up or log in to your account
# 3. Create a new application or select existing one
# 4. Copy the Application ID from the application settings
# 5. (Optional) Generate an API token in the API section for advanced features
